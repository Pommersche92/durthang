# Maintainer: Raimo Geisel <raimog92@protonmail.com>
#
# This file lives in scripts/aur/PKGBUILD as a reference template.
# The release script (scripts/aur/update-aur.sh) writes the actual
# published version into the AUR git repository with the correct
# pkgver and sha256sums filled in.
#
# To test this locally before publishing:
#   cp scripts/aur/PKGBUILD /tmp/durthang-bin/
#   cd /tmp/durthang-bin
#   makepkg -si

pkgname=durthang-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="A modern, terminal-based MUD client with TLS, GMCP, automap, aliases, triggers, and a sidebar panel system"
arch=('x86_64')
url="https://github.com/Pommersche92/durthang"
license=('GPL-3.0-only')
provides=('durthang')
conflicts=('durthang')

source_x86_64=(
  "durthang-${pkgver}-x86_64-linux.tar.gz::https://github.com/Pommersche92/durthang/releases/download/v${pkgver}/durthang-${pkgver}-x86_64-linux.tar.gz"
)
sha256sums_x86_64=('SKIP')  # filled in by update-aur.sh

package() {
  install -Dm755 "${srcdir}/durthang" "${pkgdir}/usr/bin/durthang"
}
